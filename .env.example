# Copy this file to .env and fill in real values. Never commit .env.
# ---------------------------------------------------------------------------

# Application
REGMON_ENV=development            # development | staging | production
REGMON_LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR
REGMON_LOG_FORMAT=console         # console | json
REGMON_DRY_RUN=true               # when true, no external notifications are sent

# Storage
REGMON_DATABASE_URL=sqlite:///./data/regmon.sqlite
REGMON_VECTORSTORE_PATH=./data/vectorstore

# LLM / embedding provider (pluggable; "mock" runs fully offline)
REGMON_LLM_PROVIDER=mock          # mock | openai
REGMON_EMBEDDING_PROVIDER=mock    # mock | openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Crawler
REGMON_CRAWL_USER_AGENT=regmon-bot/0.1 (+https://example.com/bot)
REGMON_CRAWL_RATE_LIMIT_PER_SEC=1
REGMON_CRAWL_TIMEOUT_SECONDS=30

# Notifications
REGMON_SLACK_WEBHOOK_URL=
REGMON_SMTP_HOST=
REGMON_SMTP_PORT=587
REGMON_SMTP_USERNAME=
REGMON_SMTP_PASSWORD=
REGMON_NOTIFY_FROM=regmon@example.com
REGMON_NOTIFY_TO=compliance-team@example.com
